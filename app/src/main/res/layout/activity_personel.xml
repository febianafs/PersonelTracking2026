<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1A2F"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:fitsSystemWindows="true"
    tools:context=".ui.personel.PersonelActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TOOLBAR -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/secondary"
            app:contentInsetStart="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

<!--                <ImageView-->
<!--                    android:layout_width="28dp"-->
<!--                    android:layout_height="28dp"-->
<!--                    android:src="@drawable/ic_logo_polri"-->
<!--                    android:contentDescription="Logo"/>-->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personel Tracking"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_toolbar_stripes"/>

                <ImageButton
                    android:id="@+id/btnOverflow"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_more_vert"
                    android:contentDescription="More options"
                    app:tint="@color/white"
                    android:scaleType="centerInside"/>

            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- CARD PROFIL -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/background"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- AVATAR + NAME + PIN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_launcher_background"
                        android:background="#0D2138"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Solah Vicenzio"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:ellipsize="end"
                            android:maxLines="1"/>

                        <TextView
                            android:id="@+id/tvNRP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NRP 123456789"
                            android:textColor="#90CAF9"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:id="@+id/btnDataSelengkapnya"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="View full data ›"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>

<!--                    <ImageButton-->
<!--                        android:id="@+id/btnDetailLocation"-->
<!--                        android:layout_width="38dp"-->
<!--                        android:layout_height="38dp"-->
<!--                        android:src="@drawable/ic_location_pin"-->
<!--                        android:background="@drawable/bg_icon_pin"-->
<!--                        android:contentDescription="Detail Location"-->
<!--                        android:scaleType="centerInside"-->
<!--                        android:padding="6dp"-->
<!--                        app:tint="@color/white"/>-->

                </LinearLayout>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A3A5C"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"/>

                <!-- LAST SYNC ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iconSync"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_sync"
                        app:tint="#90CAF9"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last sync"
                        android:textColor="#90CAF9"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvLastSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 seconds ago"
                        android:textColor="#69F0AE"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:layout_marginStart="6dp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <View
                        android:id="@+id/dotLastSync"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_connected"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ROW: VITAL SIGNS (40%) + PETA (60%) -->
        <LinearLayout
            android:id="@+id/layoutMainRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardProfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- KOLOM KIRI: VITAL SIGNS 40% -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVitalSigns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- TITLE -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_heart"
                            app:tint="#FF5252"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vital Signs"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <!-- HEART RATE -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heart Rate"
                        android:textColor="@color/gray"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvHeartRate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="87 BPM"
                        android:textColor="#FF5252"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="3dp"/>

                    <ProgressBar
                        android:id="@+id/progressHeartRate"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginBottom="8dp"
                        android:progress="65"
                        android:progressTint="#FF5252"
                        android:progressBackgroundTint="#1A3A5C"/>

                    <!-- BATTERY -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery"
                        android:textColor="@color/gray"
                        android:textSize="10sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvBattery"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="75%"
                            android:textColor="#69F0AE"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginBottom="3dp"/>

                        <ImageView
                            android:id="@+id/iconBattery"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_battery_full"
                            app:tint="#69F0AE"/>

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBattery"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginBottom="8dp"
                        android:progress="75"
                        android:progressTint="#69F0AE"
                        android:progressBackgroundTint="#1A3A5C"/>

                    <!-- GPS SIGNAL -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS Signal"
                        android:textColor="@color/gray"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvGpsSignal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Strong"
                        android:textColor="#4FC3F7"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="3dp"/>

                    <ProgressBar
                        android:id="@+id/progressGps"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginBottom="8dp"
                        android:progress="90"
                        android:progressTint="#4FC3F7"
                        android:progressBackgroundTint="#1A3A5C"/>

                    <!-- MQTT STATUS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MQTT"
                        android:textColor="@color/gray"
                        android:textSize="10sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <View
                            android:id="@+id/dotMqtt"
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@drawable/bg_dot_connected"
                            android:layout_marginEnd="5dp"/>

                        <TextView
                            android:id="@+id/tvMqttStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connected"
                            android:textColor="#69F0AE"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <!-- SEND INTERVAL -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1A3A5C"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send Interval"
                        android:textColor="@color/gray"
                        android:textSize="10sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="3dp">

                        <TextView
                            android:id="@+id/tvInterval"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="5s"
                            android:textColor="#4FC3F7"
                            android:textStyle="bold"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/btnUbahInterval"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Change"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- KOLOM KANAN: PETA 60% -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- TITLE + ZONE STATUS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_location_pin"
                            app:tint="@color/primary"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Position"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvZoneStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In Zone ✓"
                            android:textColor="#69F0AE"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"/>

                        <!-- ICON LAYERS — ganti tipe map -->
                        <ImageButton
                            android:id="@+id/btnMapType"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@drawable/ic_layers"
                            android:background="@drawable/bg_icon_pin"
                            android:contentDescription="Map Type"
                            android:scaleType="centerInside"
                            android:padding="4dp"
                            app:tint="@color/white"/>

                    </LinearLayout>

                    <!-- MAP VIEW -->
                    <org.osmdroid.views.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="6dp"/>

                    <!-- KOORDINAT + VIEW FULL MAP -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#0D2138"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:src="@drawable/ic_location_pin"
                            app:tint="#90CAF9"
                            android:layout_marginEnd="5dp"/>

                        <TextView
                            android:id="@+id/tvCoordinates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-7.868729,"
                            android:textColor="#90CAF9"
                            android:textSize="9sp"
                            android:typeface="monospace"/>

                        <TextView
                            android:id="@+id/tvCoordinates2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" 105.643117"
                            android:textColor="#90CAF9"
                            android:textSize="9sp"
                            android:typeface="monospace"
                            android:layout_marginStart="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"/>

                        <TextView
                            android:id="@+id/btnFullMap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full map ›"
                            android:textColor="@color/primary"
                            android:textSize="10sp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:paddingStart="8dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>